{
  "name": "roux-template",
  "version": "0.1.0",
  "description": "Hair salon CMS template — built with Roux UI",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3001 | xargs kill -9 2>/dev/null; bash scripts/dev-open-browser.sh & next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:reset": "dotenv -e .env.local -- tsx db/reset.ts",
    "db:seed": "dotenv -e .env.local -- tsx db/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^0.10.4",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.5.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.38.3",
    "framer-motion": "^11.11.0",
    "gsap": "^3.12.5",
    "locomotive-scroll": "^5.0.0-beta.13",
    "lucide-react": "^0.454.0",
    "next": "15.5.20",
    "next-auth": "^4.24.11",
    "next-cloudinary": "^6.17.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-dropzone": "^15.0.0",
    "react-easy-crop": "^6.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.53.0",
    "react-icons": "^5.3.0",
    "resend": "^4.0.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-google-recaptcha": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^8",
    "eslint-config-next": "15.5.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
