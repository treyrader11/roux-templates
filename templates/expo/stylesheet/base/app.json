{
  "expo": {
    "name": "roux-template",
    "slug": "roux-template",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "roux-template",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "backgroundColor": "#ffffff" } },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router"],
    "experiments": { "typedRoutes": true }
  }
}
